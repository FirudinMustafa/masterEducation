# ─── Copy to .env (dev) or set in hosting platform (prod) ───────────────────

# Postgres baglantisi. Prod icin Railway/Neon/Supabase DSN.
DATABASE_URL="postgresql://postgres@localhost:5432/master_education"

# NextAuth: gecenleri ve cookie imzalamasi icin.
# Prod'da mutlaka 64+ char rastgele string. Uretmek icin:
#   npx tsx scripts/generate-secret.ts
NEXTAUTH_SECRET=""

# Prod'da gercek domain, ornek: https://mastereducation.com.tr
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Hepsi bos = DRYRUN modu (email console'a yazilir ve EmailLog tablosuna
# DRYRUN statusuyle kaydedilir). Prod'da doldurmak zorunlu.
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS=""                             # Resend API key
SMTP_FROM="Master Education <no-reply@mastereducation.com.tr>"

# Bayi basvuru ve sistem bildirimleri icin.
ADMIN_EMAIL="info@mastereducation.com.tr"

# ─── Mock odeme (3D Secure + OTP=123456) ────────────────────────────────────
# Dev/test'te otomatik acik. Prod'da kapali; staging'de acmak icin "true".
# Gercek gateway (Iyzico/PayTR) devreye alindiginda bu flag ile mock kapatilir.
ENABLE_MOCK_PAYMENTS=""

# ─── Cron (Vercel Cron / external scheduler) ────────────────────────────────
# /api/cron/* endpoint'lerini imzalamak icin Bearer token. Bos birakilirsa
# endpoint'ler 503 doner (kazara public erisim engellenir).
# Uretmek icin: npx tsx scripts/generate-secret.ts
CRON_SECRET=""

# ─── KolayBi e-fatura entegrasyonu ──────────────────────────────────────────
# Sandbox: https://ofis-sandbox-api.kolaybi.com (default — KOLAYBI_BASE_URL bos birakilirsa)
# Prod:    https://ofis-api.kolaybi.com
# Hepsi bos = DRYRUN modu (Invoice DB'ye yazılır, KolayBi'ye istek atilmaz).
# Channel bilgisi: api.support@kolaybi.com'dan talep et.
# API key: KolayBi panel → Ayarlar → Profil Hesabı → API Anahtarları
KOLAYBI_BASE_URL=""
KOLAYBI_API_KEY=""
KOLAYBI_CHANNEL=""
# Test/dev modu — KOLAYBI_MOCK=true olunca adapter HTTP atmaz, deterministic
# synthetic ID döndürür. Credentials gelmeden bile end-to-end fatura akışı
# test edilebilir. Production'da MUTLAKA bos / "false" olmalı.
KOLAYBI_MOCK=""

# ─── Vercel Blob (dosya depolama) ───────────────────────────────────────────
# Bayi belgeleri (private) ve ürün görselleri (public) bu storage'a yazılır.
# Vercel'de Storage → Blob → Connect Store yaptıktan sonra otomatik gelir;
# `vercel env pull` çalıştırıldığında lokal .env'e dolar.
# Lokal dev'de bu env BOŞ ise dosya yüklemeleri başarısız olur (kasıtlı).
BLOB_READ_WRITE_TOKEN=""

# Ürün görselleri (public) için Blob store base URL'i.
# Format: https://<store-id>.public.blob.vercel-storage.com
# Bos birakilirsa frontend lokal /images/products/ yolunu kullanir (dev fallback).
NEXT_PUBLIC_BLOB_BASE_URL=""

# ─── Seed default admin ─────────────────────────────────────────────────────
# Seed çalışırken admin@mastereducation.com.tr için kullanılan parola.
# Boş bırakılırsa rastgele 24 karakterlik güçlü parola üretilir ve console'a
# basılır — production'da bu çıktıyı kaydedip env'e koyun.
SEED_ADMIN_PASSWORD=""

# ─── Yasal / Marka (KVKK + Mesafeli Satış uyumu) ────────────────────────────
# Boş ise constants.ts default'una düşer (canlıya çıkarken DOLDURMAK ZORUNLU).
# 6502 Tüketici Kanunu + Mesafeli Sözleşmeler Yön. — vergi bilgileri sözleşmede
# zorunlu; KolayBi e-Fatura entegrasyonu da bu alanlar olmadan çalışmaz.
BRAND_TAX_OFFICE=""
BRAND_TAX_NUMBER=""
BRAND_MERSIS_NUMBER=""

# ─── Iyzico (Faz 4.2) ──────────────────────────────────────────────────────
# Sandbox panel: https://sandbox-merchant.iyzipay.com → API anahtarları.
# Prod URL: https://api.iyzipay.com  (sandbox: https://sandbox-api.iyzipay.com)
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# ─── Shipentegra (Faz 4.3b) ────────────────────────────────────────────────
# Tek API arkasında 9 carrier (Aras/Yurtiçi/MNG/PTT/Sürat/KolayGelsin/HepsiJet/
# Trendyol/UPS). Webhook secret ile body HMAC-SHA256 verify.
SHIPENTEGRA_API_KEY=""
SHIPENTEGRA_BASE_URL="https://api.shipentegra.com/v1"
SHIPENTEGRA_WEBHOOK_SECRET=""

# ─── Upstash Redis (Faz 4.4) ───────────────────────────────────────────────
# Distributed sliding-window rate-limit. Prod'da MUTLAKA set; serverless'da
# in-memory limiti horizontal scale'de bypass'lanır (P1-DEPLOY-2).
# Upstash console → Redis Database → REST API tabı.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Sentry (Faz 4.6) ──────────────────────────────────────────────────────
# Format: https://<key>@<host>/<project_id>
# DSN yoksa lib/sentry.ts no-op — error-log.ts sadece DB'ye yazar.
SENTRY_DSN=""
SENTRY_ENVIRONMENT=""
SENTRY_RELEASE=""

# ─── Slack alert (P0 incident notification) ────────────────────────────────
# Webhook URL — incoming webhook integration. Boşsa alert gönderilmez.
SLACK_ALERT_WEBHOOK=""
