# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Product images (extracted from thumbs.zip — production'da Vercel Blob'a yüklenir)
/public/images/products

# Private uploads (auth-gated belgeler — repo'ya commit etme)
/private/

# Eski public uploads (Faz 16'da private/'a taşındı; tekrar oluşmasın diye)
/public/uploads/

# IDE / editor state
/.vs/
/.vscode/
/.idea/

# Tooling caches & artifacts (repo'ya commit etmeyiz)
/.audit/
/.claude/
/test-results/
/playwright-report/
/coverage/

# Local env scratch (.env.example haricinde — yukarıda zaten yakalanıyor)
